# ============================================================================
# Shared
# ============================================================================
# Laravel API. The bots log in as the service account below and re-use the JWT.
BACKEND_URL=http://127.0.0.1:8000/api/v1
BACKEND_LOGIN=admin@eventflats.uz
BACKEND_PASSWORD=password

LOG_LEVEL=INFO

# ============================================================================
# Admin bot  —  internal, just opens the WebApp
# ============================================================================
# Telegram token (BotFather → @BotFather → /newbot)
ADMIN_BOT_TOKEN=
# Public HTTPS URL of the admin WebApp. Telegram rejects http://.
ADMIN_WEBAPP_URL=

# ============================================================================
# Client bot  —  customer-facing LLM chat
# ============================================================================
CLIENT_BOT_TOKEN=

# OpenAI (ChatGPT). gpt-4o-mini is a fine default; override per environment.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: set to point at Azure / a proxy / a self-hosted gateway.
# OPENAI_BASE_URL=

# How many user+assistant turns to keep per conversation
HISTORY_TURNS=8
