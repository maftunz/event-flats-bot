# Telegram bot token from @BotFather
BOT_TOKEN=

# Backend API base URL (must include /api/v1)
BACKEND_URL=http://127.0.0.1:8000/api/v1

# Service account on the backend that the bot uses to read public listings.
# Set this to an admin account's login/password — the bot logs in at startup
# and caches the JWT for subsequent calls.
BACKEND_LOGIN=admin@eventflats.uz
BACKEND_PASSWORD=password

# Optional: log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
